datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Role {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  users     User[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String
  roleId    Int
  role      Role      @relation(fields: [roleId], references: [id])
  phone     String?
  avatar    String?
  lastLoginAt DateTime?
  otpCode     String?
  otpExpiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Firm {
  id          Int       @id @default(autoincrement())
  code        String?   @unique
  name        String
  address     String?
  gstNumber   String?
  panNumber   String?
  mobile      String?
  mobile2     String?
  email       String?
  stateCode   String?
  website     String?
  logo        String?
  status      Boolean   @default(true)
  companyId   Int?
  company     Company?  @relation(fields: [companyId], references: [id])
  buyers      Buyer[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
}

model Company {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  logo        String?
  address     String?
  gst         String?
  phone       String?
  status      Boolean   @default(true)
  firms       Firm[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
}


model Buyer {
  id              Int       @id @default(autoincrement())
  code            String    @unique
  name            String
  firmId          Int
  firm            Firm      @relation(fields: [firmId], references: [id])
  mobile          String?
  mobile2         String?
  email           String?
  gst             String?
  pan             String?
  stateCode       String?
  branchName      String?
  billingAddress  String?
  shippingAddress String?
  branches        BuyerBranch[]
  carts           Cart[]
  orders          Order[]
  productRequests ProductRequest[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
}

model BuyerBranch {
  id              Int       @id @default(autoincrement())
  buyerId         Int
  buyer           Buyer     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  branchName      String
  billingAddress  String
  shippingAddress String
  city            String
  state           String
  pincode         String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
}

model Transporter {
  id          Int       @id @default(autoincrement())
  name        String
  mobile      String?
  email       String?
  address     String?
  gstNumber   String?
  orders      Order[]
  dispatches  Dispatch[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
}

model Weaver {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  name        String
  looms       Loom[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
}

model Loom {
  id          Int       @id @default(autoincrement())
  loomNo      String
  weaverId    Int
  weaver      Weaver    @relation(fields: [weaverId], references: [id], onDelete: Cascade)
  designId    Int?
  design      Design?   @relation(fields: [designId], references: [id])
  assignedColor String?
}

model DesignCategory {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  name        String
  designs     Design[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
}

model Design {
  id              Int       @id @default(autoincrement())
  code            String    @unique
  name            String
  categoryId      Int
  category        DesignCategory @relation(fields: [categoryId], references: [id])
  color           String?
  colorStock      String?   @db.Text
  rate            Float
  gstPercent      Float     @default(5.0)
  material        String?
  availableStock  Int       @default(0)
  image           String?   @db.Text
  imageColorMap   String?   @db.Text
  looms           Loom[]
  
  cartItems       CartItem[]
  orderItems      OrderItem[]
  productRequestItems ProductRequestItem[]
  inventoryTxns   InventoryTransaction[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
}

model Cart {
  id          Int       @id @default(autoincrement())
  buyerId     Int       @unique
  buyer       Buyer     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  items       CartItem[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model CartItem {
  id          Int       @id @default(autoincrement())
  cartId      Int
  cart        Cart      @relation(fields: [cartId], references: [id], onDelete: Cascade)
  designId    Int
  design      Design    @relation(fields: [designId], references: [id])
  color       String?
  quantity    Int       @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Order {
  id              Int       @id @default(autoincrement())
  orderNumber     String    @unique
  buyerId         Int
  buyer           Buyer     @relation(fields: [buyerId], references: [id])
  transporterId   Int?
  transporter     Transporter? @relation(fields: [transporterId], references: [id])
  orderDate       DateTime  @default(now())
  gstAmount       Float     @default(0.0)
  totalAmount     Float     @default(0.0)
  grandTotal      Float     @default(0.0)
  remarks         String?
  status          OrderStatus @default(PENDING)
  items           OrderItem[]
  approvals       Approval[]
  dispatches      Dispatch[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
}

enum OrderStatus {
  PENDING
  APPROVED
  PROCESSING
  DISPATCHED
  COMPLETED
  CANCELLED
}

model OrderItem {
  id          Int       @id @default(autoincrement())
  orderId     Int
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  designId    Int
  design      Design    @relation(fields: [designId], references: [id])
  color       String?
  quantity    Int
  rate        Float
  taxPercent  Float
  taxAmount   Float
  lineTotal   Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Approval {
  id          Int       @id @default(autoincrement())
  orderId     Int
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  approvedBy  Int 
  status      String    
  remarks     String?
  createdAt   DateTime  @default(now())
}

model Dispatch {
  id              Int       @id @default(autoincrement())
  dispatchNumber  String    @unique
  orderId         Int
  order           Order     @relation(fields: [orderId], references: [id])
  transporterId   Int
  transporter     Transporter @relation(fields: [transporterId], references: [id])
  numberOfBundles Int
  trackingNumber  String?
  bookingCopy     String?   
  invoiceCopy     String?   
  status          DispatchStatus @default(PROCESSING)
  items           DispatchItem[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
}

enum DispatchStatus {
  PROCESSING
  DISPATCHED
  DELIVERED
}

model DispatchItem {
  id          Int       @id @default(autoincrement())
  dispatchId  Int
  dispatch    Dispatch  @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  orderItemId Int 
  quantity    Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model InventoryTransaction {
  id          Int       @id @default(autoincrement())
  designId    Int
  design      Design    @relation(fields: [designId], references: [id])
  color       String?
  type        TxnType   
  quantity    Int       
  orderRef    String?   
  createdAt   DateTime  @default(now())
}

enum TxnType {
  ORDER
  RETURN
  ADJUSTMENT
}

model Notification {
  id          Int       @id @default(autoincrement())
  userId      Int
  type        String    
  message     String
  channel     String    
  readAt      DateTime?
  createdAt   DateTime  @default(now())
}

model ProductRequest {
  id              Int                  @id @default(autoincrement())
  requestNumber   String               @unique
  buyerId         Int
  buyer           Buyer                @relation(fields: [buyerId], references: [id])
  remarks         String?              @db.Text
  status          ProductRequestStatus @default(PENDING)
  items           ProductRequestItem[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?
}

enum ProductRequestStatus {
  PENDING
  APPROVED
  COMPLETED
  REJECTED
}

model ProductRequestItem {
  id               Int            @id @default(autoincrement())
  productRequestId Int
  productRequest   ProductRequest @relation(fields: [productRequestId], references: [id], onDelete: Cascade)
  designId         Int
  design           Design         @relation(fields: [designId], references: [id])
  color            String?
  quantity         Int
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}
